{
  "lastChangelogVersion": "0.70.0",
  "defaultProvider": "github-copilot",
  "defaultModel": "claude-opus-4.5",
  "defaultThinkingLevel": "medium",
  "theme": "light",
  "skills": [
    "~/.claude/skills"
  ],
  "packages": [
    "npm:pi-mcp-adapter",
    "npm:pi-sandbox",
    "npm:pi-mermaid",
    "npm:pi-web-access",
    "npm:pi-subagents"
  ],
  "quietStartup": true,
  "subagents": {
    "agentOverrides": {
      "scout": { "model": "github-copilot/gpt-5.4-mini" },
      "planner": { "model": "github-copilot/claude-sonnet-4.5" },
      "worker": { "model": "github-copilot/claude-sonnet-4.5" },
      "reviewer": { "model": "github-copilot/claude-sonnet-4.5" },
      "context-builder": { "model": "github-copilot/claude-sonnet-4.5" },
      "researcher": { "model": "github-copilot/claude-sonnet-4.5" },
      "oracle": { "model": "github-copilot/claude-opus-4.5" },
      "oracle-executor": { "model": "github-copilot/claude-sonnet-4.5" }
    }
  }
}