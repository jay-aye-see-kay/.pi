{
  "// --- EDITOR: emacs-style movement (mostly defaults, made explicit) ---": "",                
  "tui.editor.cursorLeft":      ["left", "ctrl+b"],
  "tui.editor.cursorRight":     ["right", "ctrl+f"],
  "tui.editor.cursorWordLeft":  ["alt+left", "ctrl+left", "alt+b"],
  "tui.editor.cursorWordRight": ["alt+right", "ctrl+right", "alt+f"],
  "tui.editor.cursorLineStart": ["home", "ctrl+a"],
  "tui.editor.cursorLineEnd":   ["end", "ctrl+e"],
  "tui.editor.deleteWordBackward": ["ctrl+w", "alt+backspace"],

  "// --- EDITOR: ctrl+n/p for up/down in multiline editor ---": "",
  "tui.editor.cursorUp":   ["up", "ctrl+p"],
  "tui.editor.cursorDown": ["down", "ctrl+n"],

  "// --- LIST NAVIGATION: ctrl+n/p everywhere ---": "",   
  "tui.select.up":       ["up", "ctrl+p"],
  "tui.select.down":     ["down", "ctrl+n"],
  "tui.select.pageUp":   ["pageUp"],
  "tui.select.pageDown": ["pageDown"],
  "tui.select.confirm":  ["enter"],
  "tui.select.cancel":   ["escape", "ctrl+c"],

  "// --- INTERRUPT/EXIT: ctrl+c stops agent, ctrl+d quits when empty ---": "",
  "app.interrupt": ["escape", "ctrl+c"],
  "app.clear": ["ctrl+u"],
  "app.exit": ["ctrl+d"],

  "// --- DISPLACED: move ctrl+p away from model cycling ---": "",
  "app.model.cycleForward":  ["ctrl+y"],
  "app.model.cycleBackward": ["shift+ctrl+y"],

  "// --- MODEL SELECTOR: freed ctrl+l (use ctrl+y or /models instead) ---": "",
  "app.model.select": [],

  "// --- SESSION: ctrl+l new, ctrl+shift+l resume ---": "",
  "app.session.new":    ["ctrl+l"],
  "app.session.resume": ["shift+ctrl+l"],

  "// --- THINKING: ctrl+t cycle level, ctrl+shift+t toggle blocks ---": "",
  "app.thinking.cycle":  ["ctrl+t"],
  "app.thinking.toggle": ["ctrl+shift+t"],

  "// --- DISPLACED: move ctrl+p / ctrl+n away from session picker toggles ---": "",
  "app.session.togglePath":         ["alt+p"],
  "app.session.toggleNamedFilter":  ["alt+n"],
  "app.session.toggleSort":         ["ctrl+s"],

  "// --- INPUT: free ctrl+j for snippets extension (keep shift+enter for newline) ---": "",
  "tui.input.newLine": ["shift+enter"],

  "// --- TREE NAVIGATION ---": "",
  "app.tree.foldOrUp":   ["ctrl+left", "alt+left", "ctrl+h"],
  "app.tree.unfoldOrDown": ["ctrl+right", "alt+right", "ctrl+l"],

  "// like ctrl-x ctrl-g": "",
  "app.editor.external": ["ctrl+x"],
  "app.session.tree": ["ctrl+g"]
}
