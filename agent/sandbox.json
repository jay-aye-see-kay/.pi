{
  "enabled": true,
  "allowBrowserProcess": true,
  "network": {
    "allowLocalBinding": true,
    "allowAllUnixSockets": true,
    "allowedDomains": [
      "github.com",
      "*.github.com",
      "raw.githubusercontent.com",
      "*.npmjs.org",
      "*.pypi.org",
      "html.duckduckgo.com",
      "mcp.context7.com",
      "proxy.golang.org",
      "sum.golang.org",
      "storage.googleapis.com",
      "nixos.org",
      "*.nixos.org"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": [
      "/Users",
      "/home"
    ],
    "allowRead": [
      ".",
      "~/code",
      "~/.config",
      "~/.local",
      "~/.cache",
      "~/.pi",
      "~/.gem_cache",
      "~/.nix-profile",
      "~/hotel",
      "~/Library",
      "~/.yarnrc",
      "~/.yarnrc.yml",
      "~/.npmrc",
      "~/.npm-global",
      "/var/folders"
    ],
    "allowWrite": [
      ".",
      "/tmp",
      "~/.pi",
      "~/Library/pnpm",
      "~/.cache/uv"
    ],
    "denyWrite": [
      "~/.pi/agent/sandbox.json",
      ".env",
      ".env.*",
      "*.pem",
      "*.key"
    ]
  }
}
