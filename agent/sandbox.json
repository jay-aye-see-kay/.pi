{
  "enabled": true,
  "allowBrowserProcess": true,
  "network": {
    "allowLocalBinding": true,
    "allowAllUnixSockets": true,
    "allowedDomains": [
      "localhost",
      "github.com",
      "*.github.com",
      "*.githubcopilot.com",
      "raw.githubusercontent.com",
      "release-assets.githubusercontent.com",
      "results-receiver.actions.githubusercontent.com",
      "*.blob.core.windows.net",
      "buildkite.com",
      "api.buildkite.com",
      "buildkiteartifacts.com",
      "*.npmjs.org",
      "*.pypi.org",
      "*.crates.io",
      "html.duckduckgo.com",
      "mcp.context7.com",
      "proxy.golang.org",
      "nixos.org",
      "search.devbox.sh",
      "storage.googleapis.com",
      "sum.golang.org",
      "*.nixos.org",
      "mcp.atlassian.com",
      "cultureamp.atlassian.net",
      "*.amazonaws.com",
      "*.awsapps.com",
      "*.anthropic.com",
      "mcp.slack.com",
      "mcp.exa.ai",
      "culture-amp-be.glean.com"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": [
      "~",
      "~/Library/Keychains"
    ],
    "allowRead": [
      ".",
      "/nix",
      "/private/tmp",
      "/private/var/folders",
      "/tmp",
      "~/.agentsview",
      "~/.aws/config",
      "~/.cache",
      "~/.claude",
      "~/.claude.json",
      "~/.config",
      "~/.gem_cache",
      "~/.gradle",
      "~/.local",
      "~/.mcporter",
      "~/.nix-defexpr",
      "~/.nix-profile",
      "~/.npm-global",
      "~/.npmrc",
      "~/.pi",
      "~/.yarnrc",
      "~/.yarnrc.yml",
      "~/Downloads/",
      "~/Library/Caches",
      "~/Library/pnpm",
      "~/code",
      "~/go",
      "~/hotel",
      "~/nixfiles",
      "~/obsidian",
      "~/tmp"
    ],
    "allowWrite": [
      ".",
      "/private/tmp",
      "/private/var/folders",
      "/tmp",
      "~/.agentsview",
      "~/.cache/gh",
      "~/.cache/nix",
      "~/.cache/node",
      "~/.cache/nvim",
      "~/.cache/pre-commit",
      "~/.cache/prek",
      "~/.cache/uv",
      "~/.gradle",
      "~/.local/share/devbox",
      "~/.local/share/hotel",
      "~/.local/share/nvim",
      "~/.local/state/nvim",
      "~/.mcporter",
      "~/.pi",
      "~/Library/Caches",
      "~/Library/pnpm",
      "~/go",
      "~/tmp"
    ],
    "denyWrite": [
      "*.key",
      "*.pem",
      ".env",
      ".env.*",
      "./.pi/sandbox.json",
      "~/.pi/agent/sandbox.json"
    ]
  }
}
