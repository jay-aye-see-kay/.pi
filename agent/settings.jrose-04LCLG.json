{
  "lastChangelogVersion": "0.81.1",
  "theme": "light",
  "defaultProvider": "github-copilot",
  "defaultModel": "claude-opus-4.8",
  "defaultThinkingLevel": "medium",
  "enabledModels": [
    "github-copilot/claude-opus-4.8",
    "github-copilot/kimi-k2.7-code",
    "github-copilot/claude-sonnet-4.6",
    "anthropic/claude-fable-5"
  ],
  "subagentModels": {
    "github-copilot/kimi-k2.7-code": "good fast all-rounder, the workhorse",
    "github-copilot/claude-opus-4.8": "slower and more expensive but great for hard problems and reasoning"
  },
  "skills": [
    "~/.claude/skills"
  ],
  "quietStartup": true,
  "env": {
    "AWS_BEDROCK_FORCE_CACHE": "1",
    "PI_CACHE_RETENTION": "long"
  },
  "warnings": {
    "anthropicExtraUsage": false
  },
  "showCacheMissNotices": true,
  "terminal": {
    "showTerminalProgress": true
  },
  "collapseChangelog": true,
  "treeFilterMode": "no-tools"
}
