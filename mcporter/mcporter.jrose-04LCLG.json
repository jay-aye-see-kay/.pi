{
  "$schema": "https://raw.githubusercontent.com/steipete/mcporter/main/mcporter.schema.json",
  "mcpServers": {
    "hotel": {
      "description": "Hotel MCP — Culture Amp internal/company docs (keep-alive: corpus loads async ~10s on first start)",
      "command": "hotel",
      "args": ["mcp-server"],
      "lifecycle": "keep-alive",
      "env": {
        "HOTEL_GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "exa": {
      "description": "Exa hosted MCP — web search and page fetch",
      "baseUrl": "https://mcp.exa.ai/mcp"
    },
    "slack": {
      "description": "Slack hosted MCP (pre-registered OAuth client)",
      "baseUrl": "https://mcp.slack.com/mcp",
      "auth": "oauth",
      "oauthClientId": "1601185624273.8899143856786",
      "oauthRedirectUrl": "http://localhost:3118/callback"
    },
    "glean": {
      "description": "Glean hosted MCP (Culture Amp)",
      "baseUrl": "https://culture-amp-be.glean.com/mcp/default",
      "auth": "oauth"
    },
    "atlassian": {
      "description": "Atlassian hosted MCP — Jira and Confluence (Culture Amp)",
      "baseUrl": "https://mcp.atlassian.com/v1/mcp",
      "auth": "oauth"
    }
  }
}
